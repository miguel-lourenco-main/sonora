{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://o-guardanapo.dev/contracts/ci-fix-context.schema.json",
  "title": "CiFixContext",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skip",
    "gitlab_project_id",
    "pipeline_id",
    "sha",
    "ref",
    "job_id",
    "job_name",
    "job_stage",
    "pipeline_url",
    "log_excerpt",
    "ci_fix_iteration",
    "source",
    "verification"
  ],
  "properties": {
    "skip": { "type": "boolean" },
    "reason": { "type": "string" },
    "gitlab_project_id": { "type": "integer", "minimum": 1 },
    "pipeline_id": { "type": "integer", "minimum": 1 },
    "sha": { "type": "string", "minLength": 7 },
    "ref": { "type": "string", "minLength": 1 },
    "target_branch": { "type": "string", "minLength": 1 },
    "job_id": { "type": "integer", "minimum": 1 },
    "job_name": { "type": "string", "minLength": 1 },
    "job_stage": { "type": "string", "minLength": 1 },
    "pipeline_url": { "type": "string", "minLength": 1 },
    "log_excerpt": { "type": "string" },
    "ci_fix_iteration": { "type": "integer", "minimum": 0 },
    "source": { "type": "string", "enum": ["gitlab_ci"] },
    "verification": { "type": "string", "enum": ["gitlab_pipeline", "local_commands"] }
  },
  "allOf": [
    {
      "if": { "properties": { "skip": { "const": true } } },
      "then": { "required": ["reason", "pipeline_id", "gitlab_project_id", "ci_fix_iteration"] }
    }
  ]
}
